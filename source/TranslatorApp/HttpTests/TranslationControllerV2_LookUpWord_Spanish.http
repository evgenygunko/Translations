### Translate "afeitar" from Spanish to Russian

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "afeitar",
    "SourceLanguage": "Spanish",
    "DestinationLanguage": "Russian",
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When sending a word for translation, we expect to get json back', () => {
    client.assert(response.status === 200, "Response status is 200");

    client.assert(response.body.definition["headword"]["english"].length > 0);
    client.assert(response.body.definition["headword"]["translation"].length > 0);
    client.assert(response.body.definition.contexts[0].meanings[0]["translation"].length > 0);
    client.assert(response.body.definition.contexts[0].meanings[0]["lookupUrl"].length > 0);
  });
%}

### Translate "coche" from Spanish to Russian

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "coche",
    "SourceLanguage": "Spanish",
    "DestinationLanguage": "Russian",
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When sending a word for translation, we expect to get json back', () => {
    client.assert(response.status === 200, "Response status is 200");

    client.assert(response.body.definition["headword"]["english"].length > 0);
    client.assert(response.body.definition["headword"]["translation"].length > 0);

    client.assert(response.body.definition.contexts[0].meanings[0]["translation"].length > 0);
    client.assert(response.body.definition.contexts[1].meanings[0]["translation"].length > 0);
    client.assert(response.body.definition.contexts[2].meanings[0]["translation"].length > 0);
    client.assert(response.body.definition.contexts[3].meanings[0]["translation"].length > 0);

    client.assert(response.body.definition.contexts[0].meanings[0]["lookupUrl"].length > 0);
  });
%}

