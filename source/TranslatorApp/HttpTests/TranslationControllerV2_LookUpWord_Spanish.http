### Look up Danish text with only Spanish active dictionary - expect to get Not Found

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "stå af",
    "SourceLanguage": "Spanish",
    "DestinationLanguage": "Russian",
    "ActiveDictionaries": ["Spanish"],
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When Danish text is sent with only Spanish active dictionary, we expect not found', () => {
    client.assert(response.status === 404, "Response status is 404");
  });
%}

### BadRequest - Several required fields are null

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "coche",
    "SourceLanguage": null,
    "DestinationLanguage": null,
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When several required fields are null, we expect to get an error', () => {
    client.assert(response.status === 400, "Response status is BadRequest");
    client.assert(response.body.title === "One or more validation errors occurred.")
  });
%}
