### BadRequest - Several required fields are null

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "coche",
    "SourceLanguage": null,
    "DestinationLanguage": null,
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When several required fields are null, we expect to get an error', () => {
    client.assert(response.status === 400, "Response status is BadRequest");
    client.assert(response.body.title === "One or more validation errors occurred.")
  });
%}

### Suggested words for "xyz"

POST {{HostAddress}}/api/v2/Translation/SuggestedWords?code={{code}}
Content-Type: application/json

{
    "Text": "xyz",
    "SourceLanguage": "Spanish",
    "DestinationLanguage": "Russian",
    "Version": "2"
}

> {%

  client.test('When requesting suggested words, we expect a list in words property', () => {
    client.assert(response.status === 200, "Response status is 200");
    client.assert(response.body.words.length === 10);
    client.assert(response.body.words[0] === "xyz 1");
  });
%}

### Suggested words for Danish "islygte"

POST {{HostAddress}}/api/v2/Translation/SuggestedWords?code={{code}}
Content-Type: application/json

{
    "Text": "islygte",
    "SourceLanguage": "Danish",
    "DestinationLanguage": "Russian",
    "Version": "2"
}

> {%

  client.test('When requesting Danish suggested words for islygte, we expect DDO suggestions', () => {
    client.assert(response.status === 200, "Response status is 200");
    client.assert(Array.isArray(response.body.words), "words is an array");
    client.assert(response.body.words.length > 0, "words has at least one suggestion");
    client.assert(response.body.words.includes("lygte"), "contains 'lygte'");
    client.assert(response.body.words.includes("flygte"), "contains 'flygte'");
  });
%}

