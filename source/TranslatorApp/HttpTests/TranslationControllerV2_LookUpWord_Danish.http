### LookUpWord with Russian text returns not found

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "привет",
    "SourceLanguage": "Danish",
    "DestinationLanguage": "Russian",
    "ActiveDictionaries": ["Danish"],
    "Version": "2"
}

> {%

  client.test('When Russian text is sent to LookUpWord, we expect not found instead of parser failure', () => {
    client.assert(response.status === 404, "Response status is 404");
  });
%}

### LookUpWord with Spanish text and only Danish active dictionary returns not found

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "halagüeño",
    "SourceLanguage": "Danish",
    "DestinationLanguage": "Russian",
    "ActiveDictionaries": ["Danish"],
    "Version": "2"
}

> {%

  client.test('When Spanish text is sent with only Danish active dictionary, we expect not found', () => {
    client.assert(response.status === 404, "Response status is 404");
  });
%}
