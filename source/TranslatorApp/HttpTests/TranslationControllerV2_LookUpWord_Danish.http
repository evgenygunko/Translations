### Translate "slå" from Danish to Russian

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "slå",
    "SourceLanguage": "Danish",
    "DestinationLanguage": "Russian",
    "ActiveDictionaries": ["Danish"],
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When sending a word for translation, we expect to get json back', () => {
    client.assert(response.status === 200, "Response status is 200");
    client.assert(response.body.definition["headword"]["english"].length > 0);
    client.assert(response.body.definition["headword"]["translation"].length > 0);

    client.assert(response.body.variants[0]["url"] === "https://ordnet.dk/ddo/ordbog?select=sl%C3%A5,1&query=sl%C3%A5");
    client.assert(response.body.variants[1]["url"] === "https://ordnet.dk/ddo/ordbog?select=sl%C3%A5,2&query=sl%C3%A5");
    client.assert(response.body.variants[2]["url"] === "https://ordnet.dk/ddo/ordbog?select=sl%C3%A5%20om-nederdel&query=sl%C3%A5");

    client.assert(response.body.expressions[0]["url"] === "https://ordnet.dk/ddo/ordbog?mselect=59006368&query=sl%C3%A5");
  });
%}

### Translate a variant for "slå" from Danish to Russian

POST {{HostAddress}}/api/v2/Translation/LookUpWord?code={{code}}
Content-Type: application/json

{
    "Text": "https://ordnet.dk/ddo/ordbog?select=sl%C3%A5%20om-nederdel&query=sl%C3%A5",
    "SourceLanguage": "Danish",
    "DestinationLanguage": "Russian",
    "ActiveDictionaries": ["Danish"],
    "Version": "2"
}

> {%

  // Assert status code
  client.test('When sending a word for translation, we expect to get json back', () => {
    client.assert(response.status === 200, "Response status is 200");
    client.assert(response.body.definition["headword"]["original"] === "slå om-nederdel");
    client.assert(response.body.definition["headword"]["english"].length > 0);
    client.assert(response.body.definition["headword"]["translation"].length > 0);
  });
%}

